# PostgreSQL Configuration
POSTGRES_PASSWORD=your_secure_postgres_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_min_32_characters
JWT_SECRET_TIME=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_min_32_characters
JWT_REFRESH_SECRET_TIME=7d

# JWT Email Configuration
JWT_EMAIL_SECRET=your_jwt_email_secret_key_min_32_characters
JWT_EMAIL_SECRET_TIME=600

# AWS S3 Configuration
AWS_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# Optional S3 Configuration (for S3-compatible services)
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_FORCE_PATH_STYLE=false
# S3_PUBLIC_BASE_URL=https://your-cdn-url.com

# Application URLs
CLIENT_URL=https://melius-app.com

# Email Service (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=no-reply@melius-app.com
RESEND_FROM_NAME=Melius
RESEND_REGISTER_TEMPLATE_ALIAS=your_register_template_id
RESEND_PASSWORD_TEMPLATE_ALIAS=your_password_reset_template_id
RESEND_MEETING_TEMPLATE_ALIAS=your_meeting_template_id

# Email Configuration (optional)
# EMAIL_TOKEN_COOLDOWN_MS=600000

# Google OAuth
GOOGLE_AUTH_CLIENT_ID=your_google_client_id
GOOGLE_AUTH_CLIENT_SECRET=your_google_client_secret

# Stripe Payment
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Przelewy24 Payment (optional)
P24_MERCHANT_ID=your_merchant_id
P24_POS_ID=your_pos_id
P24_API_KEY=your_p24_api_key
P24_CRC=your_crc_key
P24_BASE_URL=https://secure.przelewy24.pl/api/v1
P24_GATEWAY_URL=https://secure.przelewy24.pl/trnRequest
P24_RETURN_URL=https://melius-app.com/payment-success
P24_STATUS_URL=https://api.melius-app.com/payments/p24/callback
P24_REFUND_STATUS_URL=https://api.melius-app.com/payments/p24/refund-callback

# Meeting Configuration (optional)
# MEETING_PENDING_TTL_MINUTES=15
# MAX_SESSIONS_PER_USER=5

# Database URL (auto-generated from POSTGRES_PASSWORD)
# DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/postgres?schema=public

# Node Environment
NODE_ENV=production
