@baseUrl = http://localhost:3000
@email = lukasik.szymon@gmail.com
@password = password123
@docId = 1
@userId = 1
@meetingId = 1
@slotId = 1

### ============================================
### USERS ENDPOINTS
### ============================================

### Create User (Full Register)
POST {{baseUrl}}/users
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}",
  "role": "user",
  "language": "pl",
  "consentTerms": true,
  "consentAdult": true,
  "consentHealthData": true
}

### Get Current User (Me)
GET {{baseUrl}}/users/me

### Get All Users (Admin only)
GET {{baseUrl}}/users

### Get User by ID (Admin only)
GET {{baseUrl}}/users/{{userId}}

### Update User
PATCH {{baseUrl}}/users/{{userId}}
Content-Type: application/json

{
  "email": "newemail@example.com",
  "language": "en"
}

### Delete User
DELETE {{baseUrl}}/users/{{userId}}

### Upload Avatar
POST {{baseUrl}}/users/avatar
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary

------WebKitFormBoundary
Content-Disposition: form-data; name="file"; filename="avatar.jpg"
Content-Type: image/jpeg

< ./path/to/avatar.jpg
------WebKitFormBoundary--

### Delete Avatar
DELETE {{baseUrl}}/users/avatar/{{userId}}

### ============================================
### AUTH ENDPOINTS
### ============================================

### Login (sets httpOnly cookie automatically)
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Register Light (no password required)
POST {{baseUrl}}/auth/register-light
Content-Type: application/json

{
  "email": "newuser@example.com",
  "firstName": "John",
  "lastName": "Doe",
  "consentTerms": true,
  "consentAdult": true,
  "consentHealthData": true
}

### Set Password (after light registration)
POST {{baseUrl}}/auth/set-password
Content-Type: application/json

{
  "password": "newpassword123"
}

### Refresh Session
POST {{baseUrl}}/auth/refresh

### Logout
POST {{baseUrl}}/auth/logout

### ============================================
### EMAIL ENDPOINTS
### ============================================

### Send Confirmation Email
POST {{baseUrl}}/email/resend-confirm
Content-Type: application/json

{
  "email": "{{email}}"
}

### Confirm Email (use token from email)
POST {{baseUrl}}/email/confirm
Content-Type: application/json

{
  "token": "YOUR_TOKEN_HERE"
}

### Send Reset Password Email
POST {{baseUrl}}/email/password
Content-Type: application/json

{
  "email": "{{email}}"
}

### Change Password (use token from email)
PATCH {{baseUrl}}/email/password-change
Content-Type: application/json

{
  "token": "YOUR_TOKEN_HERE",
  "password": "newpassword123"
}

### ============================================
### MEETINGS ENDPOINTS (USER)
### ============================================

### Get My Meetings (upcoming by default)
GET {{baseUrl}}/meetings/me

### Get My Meetings - Past
GET {{baseUrl}}/meetings/me?scope=past

### Get My Meetings - All
GET {{baseUrl}}/meetings/me?scope=all

### Create Meeting
POST {{baseUrl}}/meetings
Content-Type: application/json

{
  "slotId": {{slotId}},
  "clientMessage": "Looking forward to our meeting"
}

### Cancel My Meeting
POST {{baseUrl}}/meetings/{{meetingId}}/cancel

### ============================================
### MEETINGS ENDPOINTS (DOC)
### ============================================

### Get My Doc Meetings (upcoming)
GET {{baseUrl}}/meetings/doc?scope=upcoming

### Get My Doc Meetings - Past
GET {{baseUrl}}/meetings/doc?scope=past

### Get My Doc Meetings - All
GET {{baseUrl}}/meetings/doc?scope=cancelled

### Cancel Meeting as Doc
POST {{baseUrl}}/meetings/doc/{{meetingId}}/cancel

### ============================================
### AVAILABILITY ENDPOINTS (DOC)
### ============================================

### Create Availability Slot
POST {{baseUrl}}/availability
Content-Type: application/json

{
  "startTime": "2025-12-20T10:00:00.000Z",
  "endTime": "2025-12-20T10:50:00.000Z"
}

### Get My Availability Slots (Doc)
GET {{baseUrl}}/availability/my

### Delete Slot
DELETE {{baseUrl}}/availability/{{slotId}}

### Get Free Slots for Doc (public)
GET {{baseUrl}}/availability/doc/{{docId}}

### ============================================
### MATCHES ENDPOINTS
### ============================================

### Get My Matched Docs (User only - based on problems)
GET {{baseUrl}}/matches

### Get All Problems (public)
GET {{baseUrl}}/matches/problems

### Search Docs with Free Slots (public)
POST {{baseUrl}}/matches/search-with-slots
Content-Type: application/json

{
  "problemId": 1,
  "from": "2025-12-15T00:00:00.000Z",
  "to": "2025-12-25T23:59:59.999Z"
}

### ============================================
### PAYMENTS ENDPOINTS (STRIPE)
### ============================================

### Create Stripe Checkout Session
POST {{baseUrl}}/payments/checkout
Content-Type: application/json

{
  "meetingId": {{meetingId}}
}

### Stripe Webhook (called by Stripe, not manually)
# POST {{baseUrl}}/payments/webhook
# Requires stripe-signature header - use Stripe CLI for testing

### ============================================
### PAYMENTS ENDPOINTS (PRZELEWY24)
### ============================================

### Start P24 Payment for Meeting
POST {{baseUrl}}/payments/p24/start
Content-Type: application/json

{
  "meetingId": {{meetingId}}
}

### P24 Webhook (called by P24, not manually)
# NOTE: For testing only - real P24 will send this
POST {{baseUrl}}/payments/p24/webhook
Content-Type: application/json

{
  "sessionId": "melius-meeting-1-pay-1",
  "orderId": 123456,
  "amount": 22000,
  "currency": "PLN",
  "sign": "test_signature"
}

### ============================================
### PROFILES ENDPOINTS
### ============================================

### Get My User Profile (User only)
GET {{baseUrl}}/profiles/user

### Update My User Profile (User only)
PUT {{baseUrl}}/profiles/user
Content-Type: application/json

{
  "firstName": "Jan",
  "lastName": "Kowalski",
  "problems": [1, 2]
}

### Get My Doc Profile (Doc only)
GET {{baseUrl}}/profiles/doc

### Update My Doc Profile (Doc only)
PUT {{baseUrl}}/profiles/doc
Content-Type: application/json

{
  "firstName": "Dr",
  "lastName": "Psycholog",
  "profession": "psychologist",
  "specializations": [1, 2],
  "sessionPricePln": 220,
  "docTermsAccepted": true
}

### Update Admin Profile (Admin only)
POST {{baseUrl}}/profiles/admin
Content-Type: application/json

{
  "firstName": "Admin",
  "lastName": "User"
}

### Submit Doc Profile (Doc only)
POST {{baseUrl}}/profiles/doc/submit

### Rate Doc (User only - after completed meeting)
POST {{baseUrl}}/profiles/rate
Content-Type: application/json

{
  "docId": {{docId}},
  "meetingId": {{meetingId}},
  "rate": 5,
  "comment": "Bardzo dobra sesja!"
}

### Get Doc Ratings (public)
GET {{baseUrl}}/profiles/doc/{{docId}}/ratings?page=1&limit=10

### ============================================
### DOC VERIFICATION DOCUMENTS (DOC)
### ============================================

### Upload Verification Document
POST {{baseUrl}}/doc/verification-documents
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary

------WebKitFormBoundary
Content-Disposition: form-data; name="file"; filename="document.pdf"
Content-Type: application/pdf

< ./path/to/document.pdf
------WebKitFormBoundary--

### List Verification Documents
GET {{baseUrl}}/doc/verification-documents

### Delete Verification Document
DELETE {{baseUrl}}/doc/verification-documents/1

### ============================================
### ADMIN DOCUMENTS (ADMIN)
### ============================================

### Get Verification Document URL
GET {{baseUrl}}/admin/documents/1/url

### ============================================
### NEGATIVE CASES (UX codes)
### ============================================

### Create Meeting - slot not found (expect code: SLOT_NOT_FOUND)
POST {{baseUrl}}/meetings
Content-Type: application/json

{
  "slotId": 999999,
  "clientMessage": "test"
}

### Create Meeting - slot already booked (expect code: SLOT_ALREADY_BOOKED)
# (uruchom createMeeting 2x z tym samym slotId)
POST {{baseUrl}}/meetings
Content-Type: application/json

{
  "slotId": {{slotId}},
  "clientMessage": "test"
}

### Start P24 payment - meeting not owned (expect code: MEETING_NOT_OWNED)
POST {{baseUrl}}/payments/p24/start
Content-Type: application/json

{
  "meetingId": 999999
}

### Start P24 payment - therapist not published (expect code: THERAPIST_NOT_PUBLISHED)
# (ustaw verificationStatus != approved dla doca)
POST {{baseUrl}}/payments/p24/start
Content-Type: application/json

{
  "meetingId": {{meetingId}}
}

### Start P24 payment - session price missing (expect code: SESSION_PRICE_NOT_SET)
# (usuń sessionPricePln w docProfile)
POST {{baseUrl}}/payments/p24/start
Content-Type: application/json

{
  "meetingId": {{meetingId}}
}
